#[rewrite_local]
# 📺 BiliBili.Enhanced.x.resource.show.tab.v2
^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/resource\/show\/tab\/v2\? url script-response-body https://raw.githubusercontent.com/yrainy-0/dist/master/response.bundle.js
# 📺 BiliBili.Enhanced.x.v2.account.mine
^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/v2\/account\/mine(\/ipad)?\? url script-response-body https://raw.githubusercontent.com/yrainy-0/dist/master/response.bundle.js
# 📺 BiliBili.Enhanced.x.v2.region.index
^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/v2\/region\/index\? url script-response-body https://raw.githubusercontent.com/yrainy-0/dist/master/response.bundle.js
# 📺 BiliBili.Enhanced.x.v2.channel.region.list
^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/v2\/channel\/region\/list\? url script-response-body https://raw.githubusercontent.com/yrainy-0/dist/master/response.bundle.js
# 📺 BiliBili.Enhanced.xlive.app.interface.v2.index.feed
^https?:\/\/api\.live\.bilibili\.com\/xlive\/app-interface\/v2\/index\/feed url script-response-body https://raw.githubusercontent.com/yrainy-0/dist/master/response.bundle.js

#[mitm]
hostname = app.bilibili.com, app.biliapi.net, api.live.bilibili.com
