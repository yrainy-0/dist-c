#!name = 📺 BiliBili: ⚙️ Enhanced
#!desc = 哔哩哔哩：增强模式\n中国站功能增强及UI自定义
#!openUrl = http://boxjs.com/#/app/BiliBili.Enhanced
#!author = VirgilClyne[https://github.com/VirgilClyne]
#!homepage = https://Enhanced.BiliUniverse.io
#!icon = https://github.com/BiliUniverse/Enhanced/raw/main/src/assets/icon_rounded.png
#!category = 🪐 BiliUniverse
#!date = 2026-04-29 16:39:56
#!version = 
#!arguments = Home.Switch:true,Home.Tab:"直播tab,推荐tab,hottopic,bangumi",Home.Tab_default:"推荐tab",Home.Top_left:"mine",Home.Top:"消息Top",Bottom:"home,dynamic,我的Bottom",Region.Switch:true,Mine.Switch:true,Mine.iPad.Switch:true,Storage:"Argument",LogLevel:"WARN"
#!arguments-desc = Home.Switch: [首页] 启用此标签页自定义功能\n启用后可自定义首页标签页、顶栏按钮等内容。\n\nHome.Tab: [首页] 标签页\n    ├ 直播tab: 直播\n    ├ 推荐tab: 推荐\n    ├ hottopic: 热门\n    ├ bangumi: 番剧\n    ├ anime: 动画（港澳台）\n    ├ film: 影视\n    ├ koreavtw: 韩综（港澳台）\n    ├ game: 游戏\n    ├ mctab: minecraft\n    ├ dhtr: 动画同人\n    ├ gaoxiao: 搞笑\n    ├ school: 校园\n    └ kj: 数码\n请选择启用的首页标签页，建议不超过7个。\n\nHome.Tab_default: [首页] 默认标签页\n    ├ 直播tab: 直播\n    ├ 推荐tab: 推荐\n    ├ hottopic: 热门\n    ├ bangumi: 番剧\n    ├ anime: 动画（港澳台）\n    ├ film: 影视\n    ├ koreavtw: 韩综（港澳台）\n    ├ game: 游戏\n    ├ mctab: minecraft\n    ├ dhtr: 动画同人\n    ├ gaoxiao: 搞笑\n    ├ school: 校园\n    └ kj: 数码\n请选择启动APP时默认展示的标签页，需选择已启用的标签页。\n\nHome.Top_left: [首页] 顶栏（左侧）按钮（用户头像）\n    ├ mine: 用户中心-我的\n    └ videoshortcut: 短视频\n请选择顶栏（左侧）按钮（用户头像）的作用（在biliBili粉色版中无法修改）。\n\nHome.Top: [首页] 顶栏（右侧）按钮\n    ├ 游戏中心Top: 游戏中心\n    ├ 会员购Top: 会员购\n    └ 消息Top: 消息\n请选择启用的顶栏（右侧）按钮。\n\nBottom: [底部] 导航栏按钮\n    ├ home: 首页\n    ├ 频道Bottom: 频道\n    ├ dynamic: 动态\n    ├ publish: 发布\n    ├ ogv: 节目（港澳台）\n    ├ 会员购Bottom: 会员购\n    ├ 消息Bottom: 消息\n    └ 我的Bottom: 我的\n请选择启用的底部导航栏按钮，最多6个。\n\nRegion.Switch: [分区] 启用此标签页自定义功能\n启用后可自定义分区标签页的内容。\n\nMine.Switch: [我的] 启用此标签页自定义功能\n启用后可自定义我的标签页的服务内容。\n\nMine.iPad.Switch: [我的 iPad版] 启用此标签页自定义功能\n启用后可自定义iPad版我的标签页的服务内容。\n\nStorage: [储存] 配置类型\n    ├ Argument: 优先使用来自 $argument 的配置，$argument 不包含的设置项由 PersistentStore (BoxJs) 提供\n    ├ PersistentStore: 只使用 PersistentStore (BoxJs) 提供的配置\n    └ database: 只使用由作者的 database.mjs 文件提供的默认配置，其他任何自定义配置不再起作用\n选择要使用的配置类型。未设置此选项或不通过此选项的旧版本的配置顺序依旧是 PersistentStore (BoxJs) > $argument > database。\n\nLogLevel: [调试] 日志等级\n    ├ OFF: 关闭\n    ├ ERROR: ❌ 错误\n    ├ WARN: ⚠️ 警告\n    ├ INFO: ℹ️ 信息\n    ├ DEBUG: 🅱️ 调试\n    └ ALL: 全部\n选择脚本日志的输出等级，低于所选等级的日志将全部输出。\n

[Script]
📺 BiliBili.Enhanced.x.resource.show.tab.v2 = type=http-response, pattern=^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/resource\/show\/tab\/v2\?, requires-body=1, script-path=https://raw.githubusercontent.com/yrainy-0/dist/master/response.bundle.js, argument=Home.Switch="{{{Home.Switch}}}"&Home.Tab="{{{Home.Tab}}}"&Home.Tab_default="{{{Home.Tab_default}}}"&Home.Top_left="{{{Home.Top_left}}}"&Home.Top="{{{Home.Top}}}"&Bottom="{{{Bottom}}}"&Region.Switch="{{{Region.Switch}}}"&Mine.Switch="{{{Mine.Switch}}}"&Mine.iPad.Switch="{{{Mine.iPad.Switch}}}"&Storage="{{{Storage}}}"&LogLevel="{{{LogLevel}}}"
📺 BiliBili.Enhanced.x.v2.account.mine = type=http-response, pattern=^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/v2\/account\/mine(\/ipad)?\?, requires-body=1, script-path=https://raw.githubusercontent.com/yrainy-0/dist/master/response.bundle.js, argument=Home.Switch="{{{Home.Switch}}}"&Home.Tab="{{{Home.Tab}}}"&Home.Tab_default="{{{Home.Tab_default}}}"&Home.Top_left="{{{Home.Top_left}}}"&Home.Top="{{{Home.Top}}}"&Bottom="{{{Bottom}}}"&Region.Switch="{{{Region.Switch}}}"&Mine.Switch="{{{Mine.Switch}}}"&Mine.iPad.Switch="{{{Mine.iPad.Switch}}}"&Storage="{{{Storage}}}"&LogLevel="{{{LogLevel}}}"
📺 BiliBili.Enhanced.x.v2.region.index = type=http-response, pattern=^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/v2\/region\/index\?, requires-body=1, script-path=https://raw.githubusercontent.com/yrainy-0/dist/master/response.bundle.js, argument=Home.Switch="{{{Home.Switch}}}"&Home.Tab="{{{Home.Tab}}}"&Home.Tab_default="{{{Home.Tab_default}}}"&Home.Top_left="{{{Home.Top_left}}}"&Home.Top="{{{Home.Top}}}"&Bottom="{{{Bottom}}}"&Region.Switch="{{{Region.Switch}}}"&Mine.Switch="{{{Mine.Switch}}}"&Mine.iPad.Switch="{{{Mine.iPad.Switch}}}"&Storage="{{{Storage}}}"&LogLevel="{{{LogLevel}}}"
📺 BiliBili.Enhanced.x.v2.channel.region.list = type=http-response, pattern=^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/v2\/channel\/region\/list\?, requires-body=1, script-path=https://raw.githubusercontent.com/yrainy-0/dist/master/response.bundle.js, argument=Home.Switch="{{{Home.Switch}}}"&Home.Tab="{{{Home.Tab}}}"&Home.Tab_default="{{{Home.Tab_default}}}"&Home.Top_left="{{{Home.Top_left}}}"&Home.Top="{{{Home.Top}}}"&Bottom="{{{Bottom}}}"&Region.Switch="{{{Region.Switch}}}"&Mine.Switch="{{{Mine.Switch}}}"&Mine.iPad.Switch="{{{Mine.iPad.Switch}}}"&Storage="{{{Storage}}}"&LogLevel="{{{LogLevel}}}"
📺 BiliBili.Enhanced.xlive.app.interface.v2.index.feed = type=http-response, pattern=^https?:\/\/api\.live\.bilibili\.com\/xlive\/app-interface\/v2\/index\/feed, requires-body=1, script-path=https://raw.githubusercontent.com/yrainy-0/dist/master/response.bundle.js, argument=Home.Switch="{{{Home.Switch}}}"&Home.Tab="{{{Home.Tab}}}"&Home.Tab_default="{{{Home.Tab_default}}}"&Home.Top_left="{{{Home.Top_left}}}"&Home.Top="{{{Home.Top}}}"&Bottom="{{{Bottom}}}"&Region.Switch="{{{Region.Switch}}}"&Mine.Switch="{{{Mine.Switch}}}"&Mine.iPad.Switch="{{{Mine.iPad.Switch}}}"&Storage="{{{Storage}}}"&LogLevel="{{{LogLevel}}}"

[MITM]
hostname = %APPEND% app.bilibili.com, app.biliapi.net, api.live.bilibili.com
